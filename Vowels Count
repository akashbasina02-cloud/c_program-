#include <stdio.h>

int main() {

    char S[10001];   // Declare string (max size 10000)
    int count = 0;   // Variable to store vowel count

    fgets(S, sizeof(S), stdin);   // Read full line including spaces

    // Loop through each character of the string
    for(int i = 0; S[i] != '\0'; i++) {

        // Check if character is a vowel
        if(S[i] == 'a' || S[i] == 'e' || S[i] == 'i' ||
           S[i] == 'o' || S[i] == 'u' ||
           S[i] == 'A' || S[i] == 'E' || S[i] == 'I' ||
           S[i] == 'O' || S[i] == 'U') {

            count++;   // Increase count if vowel found
        }
    }

    printf("%d", count);   // Print total vowel count

    return 0;   // End of program
}
