#include <stdio.h>
#include <string.h>

int main() {
    
    int n;  // Number of test cases
    scanf("%d", &n);  // Read number of strings
    
    char str[105];  // Array to store each string
    
    // Loop for each test case
    for(int i = 0; i < n; i++) {
        
        scanf("%s", str);  // Read string
        
        int found = 0;  // Flag to check if digit is found
        
        // Loop through each character of string
        for(int j = 0; str[j] != '\0'; j++) {
            
            // Check if character is a digit (0-9)
            if(str[j] >= '0' && str[j] <= '9') {
                found = 1;  // Digit found
                break;      // Stop checking further
            }
        }
        
        // Print result
        if(found == 1)
            printf("Yes\n");
        else
            printf("No\n");
    }
    
    return 0;
}
