#include <stdio.h>
#include <ctype.h>   // for isupper()

int main() {
    
    char str[10001];   // given constraint: length up to 10^4
    int count = 0;
    
    // Read input string
    scanf("%s", str);
    
    // If string is not empty, first word always exists
    if (str[0] != '\0') {
        count = 1;   // first word
        
        // Traverse the string
        for (int i = 0; str[i] != '\0'; i++) {
            
            // Check if character is uppercase
            if (isupper(str[i])) {
                count++;   // new word found
            }
        }
    }
    
    // Print result
    printf("%d", count);
    
    return 0;
}
