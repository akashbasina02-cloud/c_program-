#include <stdio.h>

int main() {
    char str[10005]; // max length as per constraints
    int count = 0;

    // Read the whole line including spaces
    fgets(str, sizeof(str), stdin);

    // Count lowercase letters
    for(int i = 0; str[i] != '\0'; i++) {
        if(str[i] >= 'a' && str[i] <= 'z') {
            count++;
        }
    }

    printf("%d\n", count);
    return 0;
}
