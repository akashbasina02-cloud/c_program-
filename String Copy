#include <stdio.h>
#include <string.h>

int main() {

    char str1[10000];   // Original string
    char str2[10000];   // Destination string

    // Read full line including spaces
    fgets(str1, sizeof(str1), stdin);

    // Remove newline character if present
    str1[strcspn(str1, "\n")] = '\0';

    // Copy str1 into str2
    strcpy(str2, str1);

    // Print copied string
    printf("%s", str2);

    return 0;
}
