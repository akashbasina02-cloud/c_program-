#include <stdio.h>
#include <string.h>

int main() {
    int n;
    scanf("%d", &n);

    int x = 0;
    char str[5];

    for(int i = 0; i < n; i++) {
        scanf("%s", str);

        if(str[1] == '+')   // middle character check
            x++;
        else
            x--;
    }

    printf("%d", x);

    return 0;
}
